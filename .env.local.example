# Supabase Configuration
# Get these from your Supabase project: Settings > API

# Required for database connection
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key - ONLY for running the seed script (server-side)
# NEVER commit this or expose it to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Without these env vars, the app runs in demo mode with local data

# =============================================
# AI & Agents
# =============================================

# Anthropic API Key (required for AI features)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Managed Agent IDs (run `npx tsx scripts/setup-agents.ts` to generate)
ANTHROPIC_AGENT_INSIGHTS_ID=
ANTHROPIC_AGENT_SHIFT_REPORT_ID=
ANTHROPIC_ENVIRONMENT_ID=

# =============================================
# Email (Resend)
# =============================================

RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=CareBridge Connect <notifications@yourdomain.com>

# =============================================
# Security
# =============================================

# Bearer token for cron-triggered endpoints (daily-digest, agents)
CRON_SECRET=your-cron-secret-here

# AES-256-GCM field encryption key (64 hex chars, optional)
# FIELD_ENCRYPTION_KEY=

# =============================================
# App Config
# =============================================

NEXT_PUBLIC_SITE_URL=https://carebridgeconnect.ai
NEXT_PUBLIC_DEMO_MODE=true

# =============================================
# PCC Integration (Hybrid Model)
# =============================================

# Set to 'pcc' to use live PCC data, 'demo' to use mock PCC data, 'supabase' for old Supabase path
# Defaults to 'demo' when NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DATA_SOURCE=demo

# PCC API base URL — mock routes are built-in, no change needed for demo
# In production, set to PointClickCare's API base URL
# PCC_API_URL=https://api.pointclickcare.com/api/v1

# PCC OAuth credentials per facility (replace {FACILITY_ID} with actual facility ID)
# PCC_CLIENT_ID=your-pcc-client-id
# PCC_CLIENT_SECRET=your-pcc-client-secret

# Demo scenario mode — set to 'on' to activate archetype clinical patterns (Robert mood decline,
# Eleanor fall, Frank BP trend, Dorothy agitation). Off by default for clean random data.
# DEMO_SCENARIO=on

# OpenAI key for generating mock resident photos (one-time setup)
# Run: npx tsx scripts/generate-mock-photos.ts
# OPENAI_API_KEY=your-openai-key
