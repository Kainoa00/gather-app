# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/carebridge_messaging"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Twilio (SMS delivery) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+18015550100"   # Your Twilio number
TWILIO_WEBHOOK_URL="https://yourdomain.com/api/webhooks/twilio"

# ─── PointClickCare API ───────────────────────────────────────────────────────
PCC_CLIENT_ID="your_pcc_client_id"
PCC_CLIENT_SECRET="your_pcc_client_secret"
PCC_API_BASE="https://connect.pointclickcare.com/api/public/preview1"
PCC_WEBHOOK_SECRET="your_pcc_webhook_secret"

# ─── Twilio delivery status callback ─────────────────────────────────────────
TWILIO_STATUS_CALLBACK_URL="https://yourdomain.com/api/webhooks/twilio/status"

# ─── Webhook auth bypass (dev only) ──────────────────────────────────────────
SKIP_WEBHOOK_AUTH="false"

# ─── Demo mode (bypass auth for development) ─────────────────────────────────
DEMO_MODE="true"

# ─── Anthropic (AI personalization for compose) ──────────────────────────────
ANTHROPIC_API_KEY="your_anthropic_api_key"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3001"
